# Production Environment Variables
# Copy this to .env.local and fill in the values

# Node environment (DO NOT CHANGE IN PRODUCTION)
NODE_ENV=production

# Next.js configuration
NEXT_TELEMETRY_DISABLED=1

# Security - Generate strong secrets for production
# Use: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# Rate limiting (optional - for Redis in production)
# REDIS_URL=redis://localhost:6379

# IP Geolocation API (optional - for production use, get your own API key)
# IPAPI_ACCESS_TOKEN=your-ipapi-token
